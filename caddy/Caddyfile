# FileBrowser
cloud.dommcdev.net {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
        resolvers 1.1.1.1
    }
    #respond "Hello from Caddy! SSL for cloud is working"
    reverse_proxy filebrowser:80
}

