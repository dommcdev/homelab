# FileBrowser
cloud.dommcdev.net {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    #respond "Hello from Caddy! SSL for cloud is working"
    reverse_proxy filebrowser:80
}

# OnlyOffice Document Server CE
office.dommcdev.net {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    reverse_proxy onlyoffice:80
}

# Immich
photos.dommcdev.net {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    reverse_proxy immich-server:2283
}
