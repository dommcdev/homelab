# FileBrowser
cloud.dommcdev.net {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    #respond "Hello from Caddy! SSL for cloud is working"
    reverse_proxy filebrowser:80
}

# OnlyOffice Document Server
office.dommcdev.net {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    #respond "Hello from Caddy! SSL for onlyoffice is working"
    reverse_proxy onlyoffice:80
}

